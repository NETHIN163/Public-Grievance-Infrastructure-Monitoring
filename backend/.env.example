# ─────────────────────────────────────────────────────────
# PostgreSQL Database — Neon Cloud (https://neon.tech)
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─────────────────────────────────────────────────────────
# SMTP Configuration (for sending OTP emails)
# ─────────────────────────────────────────────────────────
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ─────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────
PORT=5000

# Change this to a long random secret in production!
JWT_SECRET=supersecretjwtkeyforgrievanceportal
